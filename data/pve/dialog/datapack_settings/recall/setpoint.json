{
    "type": "minecraft:multi_action",
    "title": {
        "text": "Set recall point for the recall system"
    },
    "body": [
        {
            "type": "minecraft:plain_message",
            "width": 500,
            "contents": {
                "text": "You're required operator permission to use this.",
                "color": "yellow",
                "italic": true,
                "underlined": true
            }
        }
    ],
    "inputs": [
        {
            "type": "minecraft:text",
            "label": "X",
            "key": "0"
        },
        {
            "type": "minecraft:text",
            "label": "Y",
            "key": "1"
        },
        {
            "type": "minecraft:text",
            "label": "Z",
            "key": "2"
        },
        {
            "type": "single_option",
            "label": "Dimension",
            "options": [
                {
                    "display": "Overworld",
                    "id": "minecraft:overworld",
                    "initial": true
                },
                {
                    "display": "The Nether",
                    "id": "minecraft:the_nether"
                },
                {
                    "display": "The End",
                    "id": "minecraft:the_end"
                }
            ],
            "key": "Dimension"
        }
    ],
    "actions": [
        {
            "label": "Set here",
            "tooltip": "Use your current coordinate as a recall point.",
            "action": {
                "type": "run_command",
                "command": "function pve:recall/setpoint/from_player_coord"
            }
        },
        {
            "label": "Set the recall point",
            "tooltip": "Please make sure you have filled all X, Y, and Z coordinate.",
            "action": {
                "type": "minecraft:dynamic/run_command",
                "template": "function pve:recall/setpoint/manual {0:$(0),1:$(1),2:$(2),Dimension:'$(Dimension)'}"
            }
        },
        {
            "label": "Back",
            "tooltip": "Go back to the recall settings.",
            "action": {
                "type": "minecraft:show_dialog",
                "dialog": "pve:datapack_settings/recall"
            }
        }
    ],
    "exit_action": {
        "label": "Cancel"
    },
    "can_close_with_escape": false
}