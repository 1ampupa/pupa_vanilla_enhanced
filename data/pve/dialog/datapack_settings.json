{
    "type": "minecraft:multi_action",
    "title": "pupa's VanillaEnhanced Datapack Settings",
    "body": [
        {
            "type": "minecraft:plain_message",
            "width": 300,
            "contents": {
                "text": "You're required operator permission to use this.",
                "color": "yellow",
                "italic": true,
                "underlined": true
            }
        }
    ],
    "columns": 2,
    "actions": [
        {
            "label": "Datapack Onboard Setup",
            "tooltip": "Run an onboard setup when you use this datapack for the first time or you upgrade your datapack version.",
            "action": {
                "type": "minecraft:run_command",
                "command": "function pve:datapack_onboard"
            },
            "width": 200
        },
        {
            "label": "Learn more",
            "tooltip": "Bring you to pupa's VanillaEnhanced Repository GitHub using your default external browser.",
            "action": {
                "type": "minecraft:open_url",
                "url": "https://github.com/1ampupa/pupa_vanilla_enhanced"
            },
            "width": 200
        },
        {
            "label": "Enable all features",
            "action": {
                "type": "minecraft:run_command",
                "command": "function pve:features_manager {afk_detection:true, death_pos:true, morning:true, morning_insomnia_effect:true, morning_wake_up_effect:true, realtime_clock:true, recall:true}"
            },
            "width": 200
        },
        {
            "label": "Disable all features",
            "action": {
                "type": "minecraft:run_command",
                "command": "function pve:features_manager {afk_detection:false, death_pos:false, morning:false, morning_insomnia_effect:false, morning_wake_up_effect:false, realtime_clock:false, recall:false}"
            },
            "width": 200
        },
        {
            "label": "AFK Detection Settings",
            "action": {
                "type": "minecraft:show_dialog",
                "dialog": "pve:datapack_settings/afk_detection"
            },
            "width": 200
        },
        {
            "label": "Death Position Settings",
            "action": {
                "type": "minecraft:show_dialog",
                "dialog": "pve:datapack_settings/death_pos"
            },
            "width": 200
        },
        {
            "label": "Morning Lifestyle Settings",
            "action": {
                "type": "minecraft:show_dialog",
                "dialog": "pve:datapack_settings/morning"
            },
            "width": 200
        },
        {
            "label": "Realtime Clock Settings",
            "action": {
                "type": "minecraft:show_dialog",
                "dialog": "pve:datapack_settings/realtime_clock"
            },
            "width": 200
        },
        {
            "label": "Recall Settings",
            "action": {
                "type": "minecraft:show_dialog",
                "dialog": "pve:datapack_settings/recall"
            },
            "width": 200
        },
        {
            "label": "Advanced Options",
            "tooltip": "Additional options for debugging and uninstallation.",
            "action": {
                "type": "minecraft:show_dialog",
                "dialog": "pve:datapack_settings/advanced_options"
            },
            "width": 200
        }
    ],
    "exit_action": {
        "label": "Close Settings"
    },
    "can_close_with_escape": false
}